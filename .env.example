# Copy to .env and fill in. NEVER commit a real .env.

# ── Provider API keys (leave blank if unused) ────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Sentinel ─────────────────────────────────────────────────────────
# Comma-separated keys that client apps use to authenticate TO Sentinel.
SENTINEL_API_KEYS=dev-local-key
PORT=8080

# ── Infrastructure ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Local models via Ollama (keyless — no quota, no rate limit) ───────
OLLAMA_BASE_URL=http://localhost:11434
JUDGE_MODEL=qwen2.5:7b
EMBED_MODEL=nomic-embed-text
